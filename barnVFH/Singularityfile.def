Bootstrap: docker
From: ros:melodic

%setup
    mkdir -p ${SINGULARITY_ROOTFS}/jackal_ws/src

%files
    . /jackal_ws/src/the-barn-challenge

%post -c /bin/bash
    # Update and install core dependencies
    apt-get update && apt-get install -y \
        python3-venv \
        protobuf-compiler \
        libprotobuf-dev \
        libgazebo9-dev \
        # ROS Melodic navigation stack (includes move_base_msgs)
        ros-melodic-navigation \
        ros-melodic-move-base-msgs \
        # Other ROS packages
        ros-melodic-gazebo-msgs \
        ros-melodic-gazebo-ros \
        ros-melodic-gazebo-ros-control \
        ros-melodic-xacro \
        ros-melodic-sick-tim \
        ros-melodic-lms1xx \
        ros-melodic-velodyne-description \
        ros-melodic-pointgrey-camera-description \
        ros-melodic-ros-control \
        ros-melodic-robot-localization \
        ros-melodic-twist-mux \
        ros-melodic-interactive-marker-twist-server \
        ros-melodic-ros-controllers \
        # Additional tools
        wget \
        git \
        python3-pip

    # Create and activate Python virtual environment
    python3 -m venv /venv
    . /venv/bin/activate
    pip3 install --upgrade pip
    pip3 install \
        defusedxml \
        rospkg \
        netifaces \
        numpy \
        transforms3d>=0.4.2 \
        scikit-fuzzy>=0.5.0 \
        scipy>=1.5.4 \
        packaging>=21.3 \
        networkx>=2.5.1

    # Clone Jackal repositories
    cd /jackal_ws/src
    git clone https://github.com/jackal/jackal.git --branch melodic-devel
    git clone https://github.com/jackal/jackal_simulator.git --branch melodic-devel
    git clone https://github.com/jackal/jackal_desktop.git --branch melodic-devel

    # Initialize ROS workspace
    source /opt/ros/melodic/setup.bash
    cd /jackal_ws
    rosdep init && rosdep update
    rosdep install -y --from-paths src --ignore-src --rosdistro melodic

    # Build the workspace
    catkin_make

    # Ensure Gazebo models are accessible
    mkdir -p /root/.gazebo/models
    echo "export GAZEBO_MODEL_PATH=/jackal_ws/src/the-barn-challenge/models:\$GAZEBO_MODEL_PATH" >> $SINGULARITY_ENVIRONMENT

%environment
    export PATH="/venv/bin:$PATH"
    export ROS_PACKAGE_PATH="/jackal_ws/src:$ROS_PACKAGE_PATH"
    source /opt/ros/melodic/setup.bash
    source /jackal_ws/devel/setup.bash
