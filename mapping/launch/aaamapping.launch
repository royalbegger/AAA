<launch>
  <arg name="map_topic" default="/map"/>
  <arg name="goal_topic" default="/move_base_simple/goal"/>
  <arg name="obstacle_layer_topic" default="/map_layers/obstacle"/>
  <arg name="unknown_layer_topic" default="/map_layers/unknown"/>
  <arg name="goal_layer_topic" default="/map_layers/goal"/>
  <arg name="process_rate" default="10.0"/>
  <arg name="unknown_cost_value" default="50"/>
  <arg name="narrow_unknown_cost_value" default="95"/>
  <arg name="narrow_unknown_width_threshold" default="0.7"/>
  <arg name="narrow_unknown_max_scan_cells" default="20"/>


  <node name="aaamapping_node" pkg="aaamapping" type="aaamapping_node" output="screen">
    <param name="map_topic" value="$(arg map_topic)"/>
    <param name="goal_topic" value="$(arg goal_topic)"/>
    <param name="obstacle_layer_topic" value="$(arg obstacle_layer_topic)"/>
    <param name="unknown_layer_topic" value="$(arg unknown_layer_topic)"/>
    <param name="goal_layer_topic" value="$(arg goal_layer_topic)"/>
    <param name="process_rate" value="$(arg process_rate)"/>
    <param name="unknown_layer/cost_value" value="$(arg unknown_cost_value)"/>
    <param name="unknown_layer/narrow_cost_value" value="$(arg narrow_unknown_cost_value)"/>
    <param name="unknown_layer/narrow_width_threshold" value="$(arg narrow_unknown_width_threshold)"/>
    <param name="unknown_layer/narrow_max_scan_cells" value="$(arg narrow_unknown_max_scan_cells)"/>
  </node>
</launch>
