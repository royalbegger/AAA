<launch>

  <arg name="scan_topic" default="$(eval optenv('JACKAL_LASER_TOPIC', 'front/scan'))" />

  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="log">
    <rosparam file="$(find gmapping_pkg)/configs/gmapping.yaml" command="load"/>
    <remap from="scan" to="$(arg scan_topic)"/>
  </node>

  <!--输出ESDF地图-->
  <node name="esdf_2d_node" pkg="gmapping_pkg" type="esdf_2d_node" output="screen"/>
</launch>